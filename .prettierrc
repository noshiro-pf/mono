{
  "plugins": [
    "prettier-plugin-organize-imports",
    "prettier-plugin-packagejson"
  ],
  "semi": true,
  "endOfLine": "lf",
  "singleQuote": true,
  "jsxSingleQuote": true,
  "overrides": [
    {
      "files": ["experimental/**/*", "packages/tools/eslint-custom-rules/**/*"],
      "options": {
        "plugins": [
          "prettier-plugin-organize-imports",
          "prettier-plugin-packagejson"
        ]
      }
    },
    {
      "files": ["**/*.md", "**/*.mdx"],
      "options": {
        "tabWidth": 4
      }
    },
    {
      "files": ["articles/**/*"],
      "options": {
        "plugins": [
          "prettier-plugin-organize-imports",
          "prettier-plugin-packagejson"
        ],
        "tabWidth": 2
      }
    }
  ]
}
